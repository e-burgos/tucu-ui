  "license": "MIT",
  "type": "module",
  "private": true,
  "scripts": {
    "tucu-ui:build": "pnpm nx run tucu-ui:build",
    "tucu-ui:publish:patch": "node scripts/publish.mjs tucu-ui patch",
    "tucu-ui:publish:minor": "node scripts/publish.mjs tucu-ui minor",
    "tucu-ui:publish:major": "node scripts/publish.mjs tucu-ui major",
    "tucu-ui:publish:dry": "node scripts/publish.mjs tucu-ui --dry-run patch",
    "mcp:publish:patch": "node scripts/publish.mjs mcp patch",
    "mcp:publish:minor": "node scripts/publish.mjs mcp minor",
    "mcp:publish:major": "node scripts/publish.mjs mcp major",
    "mcp:publish:dry": "node scripts/publish.mjs mcp --dry-run patch",
    "tucu-ui:install": "pnpm nx run tucu-ui:install:lib",
    "tucu-ui:pack": "pnpm exec nx run tucu-ui:pack:lib ",
    "tucu-ui:lint": "pnpm nx run tucu-ui:lint --verbose",
    "tucu-ui:test-local": "./scripts/toggle-local-lib.sh pack",
    "tucu-ui:test-local:npm": "./scripts/toggle-local-lib.sh npm",
    "tucu-ui:test-local:status": "./scripts/toggle-local-lib.sh status",
    "prebuild:ci": "node scripts/ensure-npm-deps.mjs",
    "demo": "pnpm nx run demo:serve",
    "demo:install": "pnpm nx run demo:app:install",
    "demo:build": "pnpm nx run demo:build",
    "test-lib": "pnpm nx run test-lib:serve",
    "test-lib:install": "pnpm nx run test-lib:app:install",
    "test-lib:build": "pnpm nx run test-lib:build",
    "harness:check": "node scripts/check-harness-symlinks.mjs",
    "evals": "node --test evals/*.eval.mjs"
  },
