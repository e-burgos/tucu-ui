{
  "name": "tucu-ui-mcp",
  "root": "tools/mcp-server",
  "sourceRoot": "tools/mcp-server/src",
  "projectType": "application",
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "options": {
        "command": "tsc -p tsconfig.lib.json",
        "cwd": "tools/mcp-server"
      }
    },
    "serve": {
      "executor": "nx:run-commands",
      "options": {
        "command": "tsx src/index.ts",
        "cwd": "tools/mcp-server"
      }
    },
    "test": {
      "executor": "nx:run-commands",
      "options": {
        "command": "vitest run",
        "cwd": "tools/mcp-server"
      }
    }
  }
}
