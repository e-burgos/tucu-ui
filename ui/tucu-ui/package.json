{
  "name": "@e-burgos/tucu-ui",
  "description": "Tucu UI Library",
  "version": "2.6.0",
  "main": "./index.js",
  "module": "./index.mjs",
  "types": "./index.d.ts",
  "style": "./index.css",
  "author": "Esteban Burgos",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/e-burgos/tucu-ui"
  },
  "keywords": [
    "ui",
    "tucu-ui",
    "e-burgos",
    "tailwind",
    "components",
    "library",
    "react",
    "zustand"
  ],
  "homepage": "https://tucu-ui.netlify.app",
  "changelog": "CHANGELOG.md",
  "exports": {
    ".": {
      "types": "./index.d.ts",
      "style": "./index.css",
      "import": "./index.mjs",
      "require": "./index.js"
    },
    "./styles": "./index.css"
  },
  "files": [
    "**/*"
  ],
  "sideEffects": true,
  "scripts": {
    "generate-props": "tsx ../../scripts/generate-props.ts",
    "publish:lib": "cd ../../dist/ui/tucu-ui && pnpm npm publish --access public --no-git-checks",
    "install:lib": "cd ../../ui/tucu-ui && pnpm install",
    "pack:lib": "cd ../../ui/tucu-ui && pnpm npm pack"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/modifiers": "^9.0.0",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@e-burgos/tucu-ui-mcp": "^0.6.0",
    "@tailwindcss/typography": "^0.5.19",
    "@tanstack/react-table": "^8.21.3",
    "@tanstack/table-core": "^8.21.3",
    "classnames": "^2.5.1",
    "framer-motion": "^12.40.0",
    "lodash": "^4.18.1",
    "lucide-react": "^1.17.0",
    "react-hook-form": "^7.77.0",
    "react-router-dom": "^7.16.0",
    "react-router": "^7.16.0",
    "react-use": "^17.6.0",
    "recharts": "^3.8.1",
    "swiper": "^12.2.0",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.3.0",
    "tailwindcss": "^4.3.0",
    "prismjs": "^1.30.0",
    "@types/prismjs": "^1.26.6",
    "@types/lodash": "^4.17.24"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0",
    "tailwindcss": ">=4.0.0"
  }
}
