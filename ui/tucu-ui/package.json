{
  "name": "@e-burgos/tucu-ui",
  "description": "Tucu UI Library",
  "version": "2.0.11",
  "main": "./index.js",
  "module": "./index.mjs",
  "types": "./index.d.ts",
  "style": "./index.css",
  "author": "Esteban Burgos",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/e-burgos/tucu-ui"
  },
  "keywords": [
    "ui",
    "tucu-ui",
    "e-burgos",
    "tailwind",
    "components",
    "library",
    "react",
    "zustand"
  ],
  "homepage": "https://tucu-ui.netlify.app",
  "changelog": "CHANGELOG.md",
  "exports": {
    ".": {
      "types": "./index.d.ts",
      "style": "./index.css",
      "import": "./index.mjs",
      "require": "./index.js"
    },
    "./styles": "./index.css"
  },
  "files": [
    "**/*"
  ],
  "sideEffects": true,
  "scripts": {
    "generate-props": "tsx ../../scripts/generate-props.ts",
    "publish:lib": "cd ../../dist/ui/tucu-ui && pnpm npm publish --access public --no-git-checks",
    "install:lib": "cd ../../ui/tucu-ui && pnpm install",
    "pack:lib": "cd ../../ui/tucu-ui && pnpm npm pack"
  },
  "dependencies": {
    "@tailwindcss/typography": "0.0.0-insiders.0339c42",
    "classnames": "^2.5.1",
    "framer-motion": "12.23.3",
    "lucide-react": "^0.460.0",
    "react-hook-form": "7.60.0",
    "react-router-dom": "7.9.1",
    "react-router": "7.9.1",
    "react-use": "^17.6.0",
    "recharts": "3.8.1",
    "swiper": "11.2.8",
    "zustand": "^5.0.8"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.1.18",
    "tailwindcss": "^4.1.18",
    "prismjs": "^1.30.0",
    "@types/prismjs": "^1.26.5"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0",
    "tailwindcss": ">=4.0.0"
  }
}
